// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  role      UserRole  @default(VIEWER)
  status    String    @default("ACTIVE")
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ItemDefinition {
  id                 String   @id @default(uuid())
  name               String
  sku                String?  @unique
  description        String?
  cost               Decimal? @db.Decimal(10, 2)
  depreciationMethod String   @default("straight-line")
  depreciationRate   Float    @default(0.20)
  isNative           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  items              Item[]
}

model Item {
  id           String         @id @default(uuid())
  definitionId String
  definition   ItemDefinition @relation(fields: [definitionId], references: [id])
  tag          String         // IN-STOCK, IN-USE, TO-SELL
  serialNumber String         @unique
  
  // Relacionamento com o Local (ItemInstance)
  locationId   String?
  location     ItemInstance?  @relation(fields: [locationId], references: [id], onDelete: SetNull)

  status       String         @default("ACTIVE")
  notes        String?        @db.Text
  
  // --- Campos para Depreciação ---
  purchaseDate     DateTime   @default(now())
  usefulLifeMonths Int        @default(60)    // Padrão 5 anos
  residualValue    Float      @default(0)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([definitionId])
  @@index([locationId])
}

model ItemInstance {
  id        String         @id @default(uuid())
  name      String   
  parentId  String?
  // O nome da relação deve ser consistente. Mudei para "LocationHierarchy" para bater com seu padrão
  parent    ItemInstance?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ItemInstance[] @relation("LocationHierarchy")
  
  // Itens vinculados a este local
  items     Item[]

  // --- NOVOS CAMPOS PARA DEPRECIAÇÃO DO ESPAÇO ---
  // (Opcionais, para casos como Racks, Containers ou móveis próprios)
  cost             Decimal?  @db.Decimal(10, 2)
  purchaseDate     DateTime?
  usefulLifeMonths Int?      @default(60)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([parentId])
}