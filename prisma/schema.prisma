// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  role      UserRole  @default(VIEWER)
  status    String    @default("ACTIVE")
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ItemDefinition {
  id          String   @id @default(uuid())
  name        String
  sku         String?  @unique
  description String?
  isNative    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Item        Item[]
}

model Item {
  id           String         @id @default(uuid())
  serialNumber ItemDefinition? @relation(fields: [serialNumber], references: [sku])        
  definitionId String
  definition   ItemDefinition @relation(fields: [definitionId], references: [id])
  tag          String // IN-STOCK, IN-USE, TO-SELL

  // Relacionamento com o Local (ItemInstance)
  locationId String?
  location   ItemInstance? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  status String  @default("ACTIVE")
  notes  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([definitionId])
  @@index([locationId])
}

model ItemInstance {
  id       String         @id @default(uuid())
  name     String         @unique
  parentId String?
  parent   ItemInstance?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children ItemInstance[] @relation("LocationHierarchy")

  // Itens vinculados a este local
  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}
