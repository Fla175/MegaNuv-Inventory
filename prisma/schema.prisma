// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum Theme {
  DARK
  LIGHT
  SISTEM
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String?
  role         UserRole  @default(VIEWER)
  theme        Theme     @default(SISTEM)
  defaultSort  String    @default("name")
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relações
  activesCreated Active[]      @relation("UserToActive")
  spacesCreated  FatherSpace[] @relation("UserToSpace")
  logs           Log[]         @relation("UserLogs")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique // Ex: "Redes", "Servidor"
  color     String?  // Opcional: para UX no frontend
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actives   Active[]
}

model Log {
  id        String   @id @default(uuid())
  action    String   // Ex: "CREATE_ACTIVE", "LOGIN", "MOVE_ACTIVE", "DELETE_USER"
  details   String   @db.Text
  ip        String?
  userAgent String?  @db.Text
  
  // Relacionamento com quem fez a ação
  userId    String?
  user      User?    @relation("UserLogs", fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model FatherSpace {
  id    String  @id
  name  String  @unique
  notes String? @db.Text

  createdById String?
  createdBy   User?   @relation("UserToSpace", fields: [createdById], references: [id])

  parentId String?
  parent   FatherSpace?  @relation("SpaceHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children FatherSpace[] @relation("SpaceHierarchy")

  actives Active[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([createdById])
}

model Active {
  id   String  @id
  name String

  // RELAÇÃO COM CATEGORY (Substituindo o Enum)
  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sku          String?
  manufacturer String?
  model        String?
  serialNumber String?
  fixedValue   Float   @default(0)

  parentId String?
  parent   Active?  @relation("ActiveHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Active[] @relation("ActiveHierarchy")

  isPhysicalSpace Boolean
  tag             String  @default("IN-STOCK")
  notes           String? @db.Text

  fatherSpaceId String
  fatherSpace   FatherSpace @relation(fields: [fatherSpaceId], references: [id])

  createdById String?
  createdBy   User?   @relation("UserToActive", fields: [createdById], references: [id])

  imageUrl String?
  fileUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fatherSpaceId])
  @@index([parentId])
  @@index([createdById])
  @@index([categoryId])
}
